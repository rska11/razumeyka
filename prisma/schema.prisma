generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Родитель — владелец аккаунта
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  phone     String?
  image     String?
  provider  String    @default("email-code")
  role      String    @default("parent") // parent | teacher
  isBlocked Boolean   @default(false)
  pdConsentAt DateTime? // согласие на обработку ПД (152-ФЗ): дата ПЕРВОГО подтверждения галочки на /login
  accessUntil     DateTime? // LEGACY: единый доступ (до перехода на доступ по направлениям). Гейтинг теперь через Access.
  paymentMethodId String?   // сохранённый способ оплаты YooKassa — задел под автопродление
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  children  Child[]
  payments  Payment[]
  accesses  Access[]
  taughtEnrollments Enrollment[] @relation("TeacherEnrollments")
}

/// Оплаченный доступ к конкретному направлению (self-study). Раздельно по направлениям:
/// одно направление = одна запись. Продлевается оплатой (см. lib/subscription.extendAccess).
model Access {
  id        String   @id @default(cuid())
  userId    String
  direction String   // risovanie | mentalnaya-arifmetika | podgotovka-k-shkole
  until     DateTime // доступ активен до этой даты
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, direction])
  @@index([userId])
}

/// Одноразовый код входа на email (как в genpic)
model EmailLoginCode {
  id        String    @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, createdAt])
}

/// Профиль ребёнка-ученика
model Child {
  id           String        @id @default(cuid())
  parentId     String
  name         String
  birthYear    Int?
  avatarColor  String?       // tailwind-класс для аватарки-инициала
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  parent       User          @relation(fields: [parentId], references: [id], onDelete: Cascade)
  enrollments  Enrollment[]
  achievements Achievement[]

  @@index([parentId])
}

/// Запись ребёнка на направление (направление + формат + тариф/срок)
model Enrollment {
  id             String     @id @default(cuid())
  childId        String
  directionSlug  String
  directionTitle String
  format         String     @default("collective") // collective | individual
  tariff         String?    // 1m | 3m | 6m
  status         String     @default("active")     // active | paused | finished | pending
  progress       Int        @default(0)            // 0..100
  daysOfWeek     String?    // CSV дни недели: "mon,thu"
  time           String?    // "18:30"
  zoomUrl        String?    // постоянная Zoom-ссылка на занятия этой записи
  teacherId      String?    // назначенный преподаватель (User с role=teacher)
  startedAt      DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  child          Child      @relation(fields: [childId], references: [id], onDelete: Cascade)
  teacher        User?      @relation("TeacherEnrollments", fields: [teacherId], references: [id], onDelete: SetNull)
  lessons        Lesson[]
  payments       Payment[]

  @@index([childId])
  @@index([teacherId])
}

/// Конкретное занятие в расписании
model Lesson {
  id           String     @id @default(cuid())
  enrollmentId String
  startsAt     DateTime
  status         String     @default("scheduled") // scheduled | done | canceled
  topic          String?
  joinUrl        String?    // Zoom-ссылка на конкретное занятие (если не задана — берётся из записи)
  reminderSentAt DateTime?  // когда отправлено email-напоминание (чтобы не дублировать)
  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, startsAt])
}

/// Достижение/награда ребёнка (прогресс)
model Achievement {
  id       String   @id @default(cuid())
  childId  String
  title    String
  icon     String?
  earnedAt DateTime @default(now())
  child    Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
}

/// Лист ожидания запуска направления. Пользователь оставляет email на «скоро»-странице
/// направления, которое ещё не открыто; на запуске по нему делается рассылка.
model Waitlist {
  id         String    @id @default(cuid())
  email      String
  direction  String    // слаг направления (speed-reading | intuition | podgotovka-k-shkole | ...)
  source     String?   // откуда пришёл (card | landing) — для аналитики
  notifiedAt DateTime? // когда отправили письмо «мы запустились»
  createdAt  DateTime  @default(now())

  @@unique([email, direction])
  @@index([direction])
}

/// Глобальные настройки-тумблеры (key-value), управляемые из админки без деплоя.
/// Сейчас: authDisabled = "true"|"false" — рубильник авторизации.
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

/// Оплата
model Payment {
  id           String      @id @default(cuid())
  userId       String
  enrollmentId String?
  purpose      String      @default("enrollment") // enrollment | subscription
  periodMonths Int?        // для подписки: на сколько месяцев продлить доступ
  directionSlug   String?   // для подписки: какое направление оплачено
  offerAcceptedAt DateTime? // когда пользователь принял оферту при оформлении оплаты
  amount       Int         // в рублях
  currency     String      @default("RUB")
  status       String      @default("pending") // pending | paid | failed | refunded
  provider     String?
  externalId   String?     @unique
  description  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}
